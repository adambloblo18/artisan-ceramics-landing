<style>
@media (max-width:960px) {
  
  /* ============================================
     1. SPACING PRIX RAVALEMENT (badge en bas hero)
     Plus d'espace au-dessus du sticky CTA
     ============================================ */
  .cmv2-hero-award {
    bottom: 7rem !important;  /* avant : 5rem */
  }
  
  /* Si dots du carousel sont là aussi, ajuster */
  .cmv2-hero-dots {
    bottom: 1.5rem !important;
  }
  
  .cmv2-hero-slide-label {
    bottom: 1.5rem !important;
  }
  
  /* Padding bottom du body pour espace sticky CTA */
  body {
    padding-bottom: 65px !important;
  }
  
  /* ============================================
     2. SUPPRESSION DU BOUTON VISUALISEUR MOBILE
     Cache la 2ème ancre (.mc-secondary qui pointe
     vers /visualiseur-ceramique/)
     ============================================ */
  .cmv2-mobile-cta a.mc-secondary[href*="visualiseur"] {
    display: none !important;
  }
  
  /* ============================================
     3. RECALIBRER LES 2 BOUTONS RESTANTS EN 50/50

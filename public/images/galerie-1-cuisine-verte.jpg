<!-- Sticky CTA Desktop -->
<div class="sticky-cta" id="stickyCta">
  <div class="sticky-cta-inner">
    <span class="sticky-cta-text">Votre projet de céramique commence ici</span>
    <a href="tel:+33670025133" class="btn btn-primary" style="padding:10px 20px; font-size:0.9rem;">📞 Appeler Laurence</a>
    <a href="/contact-ben-2/" class="btn" style="padding:10px 20px; font-size:0.9rem; border:1.5px solid #2C2A26; color:#2C2A26;">Nous écrire</a>
  </div>
</div>

<style>
.sticky-cta {
  opacity: 0;
  transform: translateY(110%);
  transition: opacity 0.45s cubic-bezier(0.2, 0.8, 0.2, 1),
              transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
  pointer-events: none;
}
.sticky-cta.is-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
</style>

<script>
(function(){
  function init() {
    var cta = document.getElementById('stickyCta');
    if (!cta) return;

    // Seuil : apparaît après avoir scrollé 80% de la hauteur du premier écran
    var threshold = window.innerHeight * 0.8;

    function onScroll() {
      if (window.scrollY > threshold) {
        cta.classList.add('is-visible');
      } else {
        cta.classList.remove('is-visible');
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', function() {
      threshold = window.innerHeight * 0.8;
    }, { passive: true });

    // Vérif initiale (au cas où la page charge déjà scrollée)
    onScroll();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script><!-- Google Ads Conversion - Appel + Email (clic) -->
<script>
document.addEventListener('DOMContentLoaded', function() {
 
  document.addEventListener('click', function(e) {
    var link = e.target.closest('a');
    if (!link) return;
    var href = link.getAttribute('href') || '';
 

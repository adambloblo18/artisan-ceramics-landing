        'send_to': 'AW-11400865534/xEpOCOKs1N8bEP7Nrbwq',
        'value': 50.0,
        'currency': 'EUR'
      });
    }
 
  });
 
});
</script><script>
(function() {
  'use strict';
  
  var CONFIG = {
    endpoint: 'https://formsubmit.co/ajax/bloch-adam@hotmail.com',
    dedupDuration: 15 * 60 * 1000,
    dailyLimit: 30
  };
  
  // Exclusion environnements de test uniquement
  var host = window.location.hostname;
  if (host.indexOf('localhost') !== -1 || host.indexOf('.local') !== -1 || host.indexOf('staging') !== -1) return;
  if (navigator.webdriver === true) return;
  
  function getParam(name) {
    try {
      var m = window.location.search.match(new RegExp('[?&]' + name + '=([^&]*)'));
      return m ? decodeURIComponent(m[1]) : '';
    } catch(e) { return ''; }
  }
  
  function getCookie(name) {
    try {
      var m = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return m ? decodeURIComponent(m[2]) : '';
    } catch(e) { return ''; }
  }
  
  function getSource() {
    try {
      if (getParam('utm_source')) return 'UTM ' + getParam('utm_source') + ' , ' + (getParam('utm_medium') || 'inconnu');
      if (getParam('gclid') || getCookie('trk_gclid')) return 'Google Ads (gclid present)';
      if (!document.referrer) return 'Direct ou marque page';
      var ref = new URL(document.referrer);
      if (ref.hostname.indexOf('google.') !== -1) return 'Google (organique)';
      if (ref.hostname.indexOf('bing.') !== -1) return 'Bing';
      if (ref.hostname.indexOf('instagram.') !== -1) return 'Instagram';
      if (ref.hostname.indexOf('facebook.') !== -1) return 'Facebook';
      if (ref.hostname.indexOf('pinterest.') !== -1) return 'Pinterest';
      if (ref.hostname === window.location.hostname) return 'Navigation interne';
      return 'Referrer ' + ref.hostname;
    } catch(e) { return 'Referrer inconnu'; }
  }
  
  function getDevice() {
    var ua = navigator.userAgent.toLowerCase();
    if (/ipad/.test(ua)) return 'iPad';
    if (/iphone|ipod/.test(ua)) return 'iPhone';
    if (/android/.test(ua)) return 'Android';
    if (/mobile/.test(ua)) return 'Mobile autre';
    return 'Desktop';
  }
  
  function checkDailyLimit() {
    try {
      var key = 'cm_alert_count_' + new Date().toISOString().slice(0, 10);
      var count = parseInt(localStorage.getItem(key) || '0', 10);
      if (count >= CONFIG.dailyLimit) return false;
      localStorage.setItem(key, (count + 1).toString());
      return true;
    } catch(e) { return true; }
  }
  
  function checkDedup(linkType, linkValue) {
    try {
      var key = 'cm_alert_sent_' + linkType + '_' + linkValue;
      var lastSent = parseInt(sessionStorage.getItem(key) || '0', 10);
      var now = Date.now();
      if (now - lastSent < CONFIG.dedupDuration) return false;
      sessionStorage.setItem(key, now.toString());
      return true;
    } catch(e) { return true; }
  }
  
  function sendAlert(linkType, linkValue, linkText) {
    try {
      var emoji = linkType === 'tel' ? 'Appel' : 'Email';
      var payload = {
        _subject: 'FormSubmit , ' + emoji + ' depuis site (' + getDevice() + ')',
        _captcha: 'false',
        _template: 'box',
        'Type intention': linkType === 'tel' ? 'Clic numero de telephone' : 'Clic email (mailto)',
        'Valeur cliquee': linkValue,
        'Texte du lien': linkText || '(vide)',
        'Page': window.location.pathname,
        'URL complete': window.location.href,
        'Source detectee': getSource(),
        'Appareil': getDevice(),
        'Heure locale Paris': new Date().toLocaleString('fr-FR', { timeZone: 'Europe/Paris' }),
        'Referrer': document.referrer || '(aucun)',
        'gclid': getParam('gclid') || getCookie('trk_gclid') || '(aucun)',
        'utm_campaign': getParam('utm_campaign') || '(aucun)',
        'utm_source': getParam('utm_source') || '(aucun)',
        'utm_medium': getParam('utm_medium') || '(aucun)'
      };
      
      fetch(CONFIG.endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload),
        keepalive: true,
        mode: 'cors'
      }).catch(function() {});
    } catch(err) {}
  }
  
  document.addEventListener('click', function(e) {
    try {
      if (!e.isTrusted) return;
      var link = e.target.closest('a[href]');
      if (!link) return;
      var href = link.getAttribute('href') || '';
      var linkType, linkValue;
      if (href.indexOf('tel:') === 0) {
        linkType = 'tel';
        linkValue = href.replace('tel:', '').replace(/\s/g, '');
      } else if (href.indexOf('mailto:') === 0) {
        linkType = 'mailto';
        linkValue = href.replace('mailto:', '').split('?')[0];
      } else {
        return;
      }
      if (!checkDedup(linkType, linkValue)) return;
      if (!checkDailyLimit()) return;
      var linkText = ((link.innerText || link.textContent || '').trim()).substring(0, 80);
      sendAlert(linkType, linkValue, linkText);
    } catch(err) {}
  }, false);
  
})();

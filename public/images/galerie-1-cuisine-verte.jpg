<!-- LAYER 4 : FAQPage -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien coûte une fresque en céramique sur mesure ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Les cabochons décoratifs démarrent à partir de 150 € pièce. Les frises de façade commencent autour de 1 000 €. Un projet complet de façade avec cabochons et frises peut aller de 3 000 à 8 000 € et au-delà. Un devis gratuit et personnalisé est fourni sous 48 heures après un premier échange."
      }
    },
    {
      "@type": "Question",
      "name": "Qui est Laurence Brecher, artiste céramiste au Vésinet ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Laurence Brecher est une artiste céramiste et mosaïste formée à l'Académie de Port-Royal et à l'École des Beaux-Arts de Paris. Depuis son atelier du Vésinet (Yvelines, 78), elle crée des fresques, mosaïques et cabochons en céramique émaillée de style Art Nouveau. Son travail a été récompensé par le Prix du Ravalement de Versailles 2024 dans la catégorie Restitution de Décors. Elle a réalisé des projets pour des restaurants (La Halle à Paris, Castor Bellux à Dinard), des façades de maisons, des crédences et des mosaïques de sol."
      }
    },
    {
      "@type": "Question",
      "name": "Comment se déroule un projet de céramique murale ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un projet se déroule en quatre étapes sur 6 à 10 semaines : 1) Un échange (appel ou visite à l'atelier) pour comprendre votre projet et votre budget. 2) La réalisation de maquettes peintes sur papier. 3) La création artisanale des carreaux, l'émaillage et la peinture à la main. 4) La cuisson au grand feu (980 °C) et la livraison avec fiche technique de pose."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est la différence entre céramique et mosaïque ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La céramique émaillée consiste à peindre un décor sur des carreaux de faïence puis à les cuire au grand feu. La mosaïque assemble de petites pièces (tesselles) pour former un motif. Laurence Brecher maîtrise les deux techniques et conseille la plus adaptée à chaque projet : la céramique peinte pour les fresques et les frises, la mosaïque pour les sols et les surfaces courbes. Elle collabore avec le mosaïste Arnaud Pereira pour les projets de mosaïque."
      }
    },
    {
      "@type": "Question",
      "name": "Peut-on commander une céramique murale pour un restaurant ou un commerce ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, l'atelier réalise des enseignes et panneaux décoratifs en céramique émaillée pour les professionnels : restaurants, bars, boulangeries, hôtels, commerces. Les céramiques Art Nouveau donnent une identité visuelle forte et élégante à votre façade. Exemples : les façades du restaurant La Halle à Paris et les six panneaux du restaurant Castor Bellux à Dinard."
      }
    },
    {
      "@type": "Question",
      "name": "Où se trouve l'atelier de céramique murale ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'atelier Les Céramiques Murales du Vésinet est situé au 14 rue Ernest André, 78110 Le Vésinet, dans les Yvelines en Île-de-France, à proximité de Paris, Versailles et Saint-Germain-en-Laye. Laurence Brecher réalise des projets partout en France, en Belgique et en Suisse, et peut se déplacer pour étudier votre projet sur place."
      }
    },
    {
      "@type": "Question",
      "name": "La céramique émaillée résiste-t-elle au gel ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Laurence Brecher utilise des techniques d'émaillage grand feu (cuisson à 980 °C) qui produisent des céramiques ingélives, c'est-à-dire résistantes au gel et aux intempéries. Les décors de façade en céramique émaillée sont conçus pour durer des décennies en extérieur sans altération des couleurs ni des motifs."
      }
    },
    {
      "@type": "Question",
      "name": "Peut-on reproduire des céramiques Art Nouveau anciennes ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Laurence Brecher est spécialisée dans la reproduction et la restitution de céramiques architecturales Art Nouveau et Art Déco. Elle peut reproduire à l'identique des cabochons, frises, médaillons et panneaux décoratifs anciens en utilisant les techniques d'émaillage traditionnelles. Son travail de restitution à Versailles a été récompensé par le Prix du Ravalement 2024."
      }
    }
  ]
}
</script>

